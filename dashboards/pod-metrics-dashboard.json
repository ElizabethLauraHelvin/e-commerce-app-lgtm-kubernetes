      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"monitoring\", container!=\"\", container!=\"POD\"}[5m])) * 1000",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage (millicores) — monitoring",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never"},
          "unit": "bytes", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 27},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"monitoring\", container!=\"\", container!=\"POD\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Memory Usage — monitoring",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35},
      "id": 103,
      "title": "📊 Resource Summary Table",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"align": "auto", "displayMode": "auto", "filterable": true},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}]}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "CPU (m)"},
            "properties": [{"id": "unit", "value": "short"}, {"id": "custom.width", "value": 100}]
          },
          {
            "matcher": {"id": "byName", "options": "Memory"},
            "properties": [{"id": "unit", "value": "bytes"}, {"id": "custom.width", "value": 120}]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 36},
      "id": 9,
      "options": {"showHeader": true, "sortBy": [{"desc": true, "displayName": "CPU (m)"}]},
      "targets": [
        {
          "expr": "sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{namespace=~\"ecommerce|monitoring\", container!=\"\", container!=\"POD\"}[5m])) * 1000",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "sum by (namespace, pod) (container_memory_working_set_bytes{namespace=~\"ecommerce|monitoring\", container!=\"\", container!=\"POD\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        }
      ],
      "title": "All Pods Resource Usage",
      "transformations": [
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {"Value #A": "CPU (m)", "Value #B": "Memory", "namespace": "Namespace", "pod": "Pod"}
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["pod", "container", "kubernetes", "aks-a"],
  "templating": {
    "list": [
      {
        "current": {"text": "Mimir-Pods", "value": "mimir-pods"},
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "Asia/Jakarta",
  "title": "Pod Metrics — AKS A",
