    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never"},
          "unit": "short", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 27},
